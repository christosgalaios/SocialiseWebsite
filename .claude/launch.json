{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "landing-page",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "const h=require('http'),f=require('fs'),p=require('path');const m={'.html':'text/html','.css':'text/css','.js':'application/javascript','.png':'image/png','.jpg':'image/jpeg','.svg':'image/svg+xml','.ico':'image/x-icon'};h.createServer((q,r)=>{let u=q.url==='/'?'/index.html':q.url;f.readFile('.'+u,(e,d)=>{if(e){r.writeHead(404);r.end('Not found')}else{r.writeHead(200,{'Content-Type':m[p.extname(u)]||'application/octet-stream'});r.end(d)}})}).listen(3000,()=>console.log('Server running on http://localhost:3000'))"],
      "port": 3000
    }
  ]
}
