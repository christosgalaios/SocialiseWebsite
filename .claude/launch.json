{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "landing-page",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "require('http').createServer((q,r)=>{require('fs').readFile(q.url==='/'?'index.html':'.'+q.url,(e,d)=>{if(e){r.writeHead(404);r.end('Not found')}else{r.writeHead(200,{'Content-Type':q.url.endsWith('.html')||q.url==='/'?'text/html':'application/octet-stream'});r.end(d)}})}).listen(3000)"],
      "port": 3000
    }
  ]
}
